    <record id="view_amr_reengagement_search" model="ir.ui.view">
        <field name="name">amr.reengagement.report.search</field>
        <field name="model">amr.reengagement.report</field>
        <field name="arch" type="xml">
            <search string="Search Re-engagement">
                <field name="email"/>
                <filter string="At Risk (30-60 days)" name="at_risk" domain="[('reengagement_status','=','At Risk')]"/>
                <filter string="Dormant (60-90 days)" name="dormant" domain="[('reengagement_status','=','Dormant')]"/>
                <filter string="Lost (90+ days)" name="lost" domain="[('reengagement_status','=','Lost')]"/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="group_status" context="{'group_by': 'reengagement_status'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_amr_reengagement" model="ir.actions.act_window">
        <field name="name">Re-engagement Opportunities</field>
        <field name="res_model">amr.reengagement.report</field>
        <field name="view_mode">list,pivot</field>
    </record>

</odoo>
