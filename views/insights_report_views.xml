<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_amr_monthly_trend_list" model="ir.ui.view">
        <field name="name">amr.monthly.trend.report.list</field>
        <field name="model">amr.monthly.trend.report</field>
        <field name="arch" type="xml">
            <list string="Monthly Trend" create="false" edit="false" delete="false">
                <field name="month_label"/>
                <field name="campaigns_sent"/>
                <field name="total_sent"/>
                <field name="total_delivered"/>
                <field name="total_opened"/>
                <field name="total_clicked"/>
                <field name="total_bounced"/>
                <field name="open_rate" string="Open %"/>
                <field name="click_rate" string="Click %"/>
                <field name="bounce_rate" string="Bounce %"/>
                <field name="delivery_rate" string="Delivery %"/>
            </list>
        </field>
    </record>

    <record id="view_amr_monthly_trend_pivot" model="ir.ui.view">
        <field name="name">amr.monthly.trend.report.pivot</field>
        <field name="model">amr.monthly.trend.report</field>
        <field name="arch" type="xml">
            <pivot string="Monthly Trend" disable_linking="True">
                <field name="year" type="col"/>
                <field name="month_label" type="row"/>
                <field name="total_sent" type="measure"/>
                <field name="total_opened" type="measure"/>
                <field name="total_clicked" type="measure"/>
                <field name="open_rate" type="measure"/>
                <field name="delivery_rate" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="view_amr_monthly_trend_graph" model="ir.ui.view">
        <field name="name">amr.monthly.trend.report.graph</field>
        <field name="model">amr.monthly.trend.report</field>
        <field name="arch" type="xml">
            <graph string="Monthly Trend" type="line">
                <field name="month_label" type="row"/>
                <field name="total_sent" type="measure"/>
                <field name="total_opened" type="measure"/>
                <field name="open_rate" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="view_amr_monthly_trend_search" model="ir.ui.view">
        <field name="name">amr.monthly.trend.report.search</field>
        <field name="model">amr.monthly.trend.report</field>
        <field name="arch" type="xml">
            <search string="Search Monthly Trend">
                <field name="month_label"/>
                <group expand="0" string="Group By">
                    <filter string="Year" name="group_year" context="{'group_by': 'year'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_amr_monthly_trend" model="ir.actions.act_window">
        <field name="name">Monthly Trend</field>
        <field name="res_model">amr.monthly.trend.report</field>
        <field name="view_mode">list,pivot,graph</field>
    </record>

    <record id="view_amr_campaign_ranking_list" model="ir.ui.view">
        <field name="name">amr.campaign.ranking.report.list</field>
        <field name="model">amr.campaign.ranking.report</field>
        <field name="arch" type="xml">
            <list string="Campaign Ranking" create="false" edit="false" delete="false">
                <field name="rank"/>
                <field name="subject"/>
                <field name="engagement_score"/>
                <field name="performance_tier"
                       decoration-success="performance_tier == 'Top Performer'"
                       decoration-warning="performance_tier == 'Average'"
                       decoration-danger="performance_tier == 'Needs Attention'"/>
                <field name="open_rate" string="Open %"/>
                <field name="click_rate" string="Click %"/>
                <field name="delivery_rate" string="Delivery %"/>
                <field name="reply_rate" string="Reply %"/>
                <field name="bounce_rate" string="Bounce %"/>
                <field name="sent_date"/>
            </list>
        </field>
    </record>

    <record id="view_amr_campaign_ranking_pivot" model="ir.ui.view">
        <field name="name">amr.campaign.ranking.report.pivot</field>
        <field name="model">amr.campaign.ranking.report</field>
        <field name="arch" type="xml">
            <pivot string="Campaign Ranking" disable_linking="True">
                <field name="performance_tier" type="row"/>
                <field name="engagement_score" type="measure"/>
                <field name="open_rate" type="measure"/>
                <field name="delivery_rate" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="view_amr_campaign_ranking_search" model="ir.ui.view">
        <field name="name">amr.campaign.ranking.report.search</field>
        <field name="model">amr.campaign.ranking.report</field>
        <field name="arch" type="xml">
            <search string="Search Campaign Ranking">
                <field name="subject"/>
                <filter string="Top Performers" name="top" domain="[('performance_tier','=','Top Performer')]"/>
                <filter string="Average" name="avg" domain="[('performance_tier','=','Average')]"/>
